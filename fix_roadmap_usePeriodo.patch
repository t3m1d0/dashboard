+Create Date: 2026-05-10
+"""
+from alembic import op
+import sqlalchemy as sa
+
+revision = '0010_gente_colaboradores_v2'
+down_revision = '0009_lojas'
+branch_labels = None
+depends_on = None
+
+
+def upgrade() -> None:
+    conn = op.get_bind()
+    from sqlalchemy import inspect, text
+    inspector = inspect(conn)
+    existing = [c['name'] for c in inspector.get_columns('gente_colaboradores')]
+
+    with op.batch_alter_table('gente_colaboradores') as batch_op:
+        if 'salario_bruto' not in existing:
+            batch_op.add_column(sa.Column('salario_bruto',        sa.Float(), nullable=True))
+        if 'salario_liquido' not in existing:
+            batch_op.add_column(sa.Column('salario_liquido',      sa.Float(), nullable=True))
+        if 'ultima_competencia' not in existing:
+            batch_op.add_column(sa.Column('ultima_competencia',   sa.String(20), nullable=True))
+        if 'primeira_competencia' not in existing:
+            batch_op.add_column(sa.Column('primeira_competencia', sa.String(20), nullable=True))
+
+    # Indexes
+    existing_idx = [i['name'] for i in inspector.get_indexes('gente_colaboradores')]
+    with op.batch_alter_table('gente_colaboradores') as batch_op:
+        if 'ix_gc_ultima_competencia' not in existing_idx:
+            batch_op.create_index('ix_gc_ultima_competencia', ['ultima_competencia'])
+        if 'ix_gc_cargo' not in existing_idx:
+            batch_op.create_index('ix_gc_cargo', ['cargo'])
+        if 'ix_gc_empresa_cargo' not in existing_idx:
+            batch_op.create_index('ix_gc_empresa_cargo', ['empresa_id', 'cargo'])
+
+
+def downgrade() -> None:
+    with op.batch_alter_table('gente_colaboradores') as batch_op:
+        batch_op.drop_index('ix_gc_empresa_cargo')
+        batch_op.drop_index('ix_gc_cargo')
+        batch_op.drop_index('ix_gc_ultima_competencia')
+        batch_op.drop_column('primeira_competencia')
+        batch_op.drop_column('ultima_competencia')
+        batch_op.drop_column('salario_liquido')
+        batch_op.drop_column('salario_bruto')
